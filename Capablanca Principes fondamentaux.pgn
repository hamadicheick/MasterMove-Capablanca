[White "Seirawan, Yasser"]
[Black "Karpov, Anatoly"]
[Result "1-0"]
[ECO "D53"]
[WhiteElo "2575"]
[BlackElo "2720"]
[Annotator "konea"]
[PlyCount "73"]
[EventDate "1982.04.??"]
